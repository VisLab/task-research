{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hed-cognitive.org/schemas/task_details.schema.json",
  "title": "HED task catalog",
  "description": "Schema for task_details.json — the canonical catalog of experimental tasks/paradigms in the HED (Hierarchical Event Descriptor) project. Top-level is a bare array of task objects (not a wrapping dict, unlike process_details.json). Covers structural shape only; cross-checks (e.g., hed_process_ids resolve to processes in process_details.json) live in Python.",

  "type": "array",
  "items": { "$ref": "#/definitions/task" },

  "definitions": {

    "task": {
      "type": "object",
      "required": [
        "hedtsk_id",
        "canonical_name",
        "short_definition",
        "description",
        "inclusion_test",
        "hed_process_ids"
      ],
      "properties": {
        "hedtsk_id": {
          "type": "string",
          "pattern": "^hedtsk_[a-z][a-z0-9_]*$",
          "description": "Task identifier with hedtsk_ prefix."
        },
        "canonical_name": { "type": "string", "minLength": 1 },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Plain string list — note this differs from process_details.json, where aliases are objects with name+note."
        },
        "short_definition": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "inclusion_test": { "$ref": "#/definitions/inclusion_test" },
        "variations": {
          "type": "array",
          "items": { "$ref": "#/definitions/variation" }
        },
        "atlas_id": {
          "type": ["string", "null"],
          "description": "Cognitive Atlas task ID; null when no Atlas equivalent."
        },
        "source_task_numbers": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "status": {
          "type": "string",
          "description": "Editorial status; current single value is 'complete' but kept open-typed for future states."
        },
        "hed_process_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^hed_[a-z][a-z0-9_]*$"
          },
          "minItems": 1,
          "description": "Process IDs implicated by this task. Each must resolve to a process in process_details.json (cross-check enforced in Python, not here)."
        },
        "references": {
          "type": "array",
          "items": { "$ref": "#/definitions/reference" }
        }
      }
    },

    "inclusion_test": {
      "type": "object",
      "additionalProperties": false,
      "required": ["procedure", "manipulation", "measurement"],
      "properties": {
        "procedure": { "type": "string", "minLength": 1 },
        "manipulation": { "type": "string", "minLength": 1 },
        "measurement": { "type": "string", "minLength": 1 }
      }
    },

    "variation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "justification"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "justification": { "type": "string", "minLength": 1 }
      }
    },

    "reference": {
      "type": "object",
      "required": ["roles"],
      "description": "Same shape as the reference object in process_details.schema.json. Most fields commonly null; only roles is strictly required.",
      "properties": {
        "roles": {
          "type": "array",
          "items": { "$ref": "#/definitions/reference_role" },
          "minItems": 1
        },
        "title": { "type": ["string", "null"] },
        "authors": { "type": ["string", "null"] },
        "year": { "type": ["integer", "null"] },
        "journal": { "type": ["string", "null"] },
        "venue": { "type": ["string", "null"] },
        "venue_type": { "type": ["string", "null"] },
        "volume": { "type": ["string", "null"] },
        "issue": { "type": ["string", "null"] },
        "pages": { "type": ["string", "null"] },
        "doi": { "type": ["string", "null"] },
        "openalex_id": { "type": ["string", "null"] },
        "pmid": { "type": ["string", "null"] },
        "url": { "type": ["string", "null"] },
        "citation_string": { "type": ["string", "null"] },
        "source": { "type": ["string", "null"] },
        "confidence": { "type": ["string", "null"] },
        "verified_on": { "type": ["string", "null"] }
      }
    },

    "reference_role": {
      "type": "string",
      "enum": [
        "historical",
        "review",
        "experiment",
        "dataset",
        "other",
        "unknown"
      ],
      "description": "Role vocabulary fixed by CLAUDE.md (2026-04-23)."
    }
  }
}
